<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001-create-alerte-table" author="senprix">
        <createTable tableName="alerte">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <!-- prix_id, produit_id et marche_id référencent des entités
                 d'autres microservices : aucune contrainte de clé étrangère
                 SQL possible, l'alerte est créée sur la foi de l'appel
                 du prix-service au moment de la détection -->
            <column name="prix_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="produit_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="marche_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="montant" type="DECIMAL(12,2)">
                <constraints nullable="false"/>
            </column>
            <column name="montant_moyen" type="DECIMAL(12,2)">
                <constraints nullable="false"/>
            </column>
            <column name="ecart_pourcentage" type="DECIMAL(6,2)">
                <constraints nullable="false"/>
            </column>
            <column name="niveau_gravite" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="statut" type="VARCHAR(20)" defaultValue="NOUVELLE">
                <constraints nullable="false"/>
            </column>
            <column name="commentaire_resolution" type="TEXT"/>
            <column name="date_creation" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="date_resolution" type="TIMESTAMP"/>
        </createTable>

        <createIndex indexName="idx_alerte_statut" tableName="alerte">
            <column name="statut"/>
        </createIndex>

        <createIndex indexName="idx_alerte_gravite" tableName="alerte">
            <column name="niveau_gravite"/>
        </createIndex>

        <createIndex indexName="idx_alerte_produit_marche" tableName="alerte">
            <column name="produit_id"/>
            <column name="marche_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
