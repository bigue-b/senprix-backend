<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="004-create-campagne-produit-table" author="senprix">
        <createTable tableName="campagne_produit">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="campagne_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <!-- produit_id référence un produit du produit-service : aucune
                 contrainte de clé étrangère SQL possible entre microservices -->
            <column name="produit_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="date_association" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="campagne_produit"
                baseColumnNames="campagne_id"
                constraintName="fk_campagne_produit_campagne"
                referencedTableName="campagne"
                referencedColumnNames="id"
                onDelete="CASCADE"/>

        <addUniqueConstraint
                tableName="campagne_produit"
                columnNames="campagne_id, produit_id"
                constraintName="uk_campagne_produit_unique"/>

        <createIndex indexName="idx_campagne_produit_produit" tableName="campagne_produit">
            <column name="produit_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
