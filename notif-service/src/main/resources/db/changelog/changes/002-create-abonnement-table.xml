<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="002-create-abonnement-table" author="senprix">
        <createTable tableName="abonnement">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="citoyen_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="citoyen_email" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="produit_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="marche_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="canal" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="date_creation" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint
                tableName="abonnement"
                columnNames="citoyen_id, produit_id, marche_id"
                constraintName="uk_abonnement_citoyen_produit_marche"/>

        <createIndex indexName="idx_abonnement_citoyen" tableName="abonnement">
            <column name="citoyen_id"/>
        </createIndex>

        <createIndex indexName="idx_abonnement_produit_marche" tableName="abonnement">
            <column name="produit_id"/>
            <column name="marche_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
