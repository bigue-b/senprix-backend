<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001-create-prix-table" author="senprix">
        <createTable tableName="prix">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <!-- produit_id, marche_id, campagne_id et agent_id référencent
                 des entités d'autres microservices : aucune contrainte de
                 clé étrangère SQL possible, la validation d'existence se
                 fait par appel HTTP synchrone au moment de la création -->
            <column name="produit_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="marche_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="campagne_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="agent_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="montant" type="DECIMAL(12,2)">
                <constraints nullable="false"/>
            </column>
            <column name="unite" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="date_releve" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="statut" type="VARCHAR(20)" defaultValue="VALIDE">
                <constraints nullable="false"/>
            </column>
            <column name="commentaire" type="TEXT"/>
            <column name="date_creation" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="idx_prix_produit_marche" tableName="prix">
            <column name="produit_id"/>
            <column name="marche_id"/>
        </createIndex>

        <createIndex indexName="idx_prix_campagne" tableName="prix">
            <column name="campagne_id"/>
        </createIndex>

        <createIndex indexName="idx_prix_agent" tableName="prix">
            <column name="agent_id"/>
        </createIndex>

        <createIndex indexName="idx_prix_statut" tableName="prix">
            <column name="statut"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
