<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001-create-produit-table" author="senprix">
        <createTable tableName="produit">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="code_produit" type="VARCHAR(20)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_produit_code"/>
            </column>
            <column name="nom" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="categorie" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="unite" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="statut" type="VARCHAR(20)" defaultValue="ACTIF">
                <constraints nullable="false"/>
            </column>
            <column name="date_creation" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="date_modification" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="idx_produit_statut" tableName="produit">
            <column name="statut"/>
        </createIndex>

        <createIndex indexName="idx_produit_categorie" tableName="produit">
            <column name="categorie"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
