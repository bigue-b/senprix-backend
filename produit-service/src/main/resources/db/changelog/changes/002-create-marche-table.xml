<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="002-create-marche-table" author="senprix">
        <createTable tableName="marche">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="nom" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="ville" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="region" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="latitude" type="DECIMAL(10,7)"/>
            <column name="longitude" type="DECIMAL(10,7)"/>
            <column name="statut" type="VARCHAR(20)" defaultValue="ACTIF">
                <constraints nullable="false"/>
            </column>
            <column name="date_creation" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="date_modification" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="idx_marche_statut" tableName="marche">
            <column name="statut"/>
        </createIndex>

        <createIndex indexName="idx_marche_region" tableName="marche">
            <column name="region"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
