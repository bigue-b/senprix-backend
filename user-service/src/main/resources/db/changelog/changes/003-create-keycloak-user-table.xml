<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="003-create-keycloak-user-table" author="senprix">
        <createTable tableName="keycloak_user">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="utilisateur_id" type="BIGINT">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_keycloak_user_utilisateur"/>
            </column>
            <column name="keycloak_id" type="VARCHAR(255)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_keycloak_user_keycloak_id"/>
            </column>
            <column name="username" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="realm" type="VARCHAR(100)" defaultValue="senprix">
                <constraints nullable="false"/>
            </column>
            <column name="enabled" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="date_synchronisation" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="keycloak_user"
                baseColumnNames="utilisateur_id"
                constraintName="fk_keycloak_user_utilisateur"
                referencedTableName="utilisateur"
                referencedColumnNames="id"
                onDelete="CASCADE"/>
    </changeSet>

</databaseChangeLog>
